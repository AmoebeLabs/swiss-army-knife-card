    "rollup": "^4.60",
    "rollup-plugin-serve": "^3",
    "@eslint/js": "",
    "@eslint/eslintrc": ""
  },
  "dependencies": {
    "@formatjs/intl-utils": "^3.8.4",
    "@mdi/js": "^7.2.96",
    "@tanem/svg-injector": "^10.1.53",
    "home-assistant-js-websocket": "^9.6.0",
    "lit-element": "^2.5.1",
    "lit-html": "^1.4.1",
    "memoize-one": "^6.0.0"
  }
